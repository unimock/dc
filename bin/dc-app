#!/bin/bash

. /opt/dc/funcs/global

_show_help() {
  echo ""
  echo " usage: `basename $0` <app>"
  echo ""
  echo "tbd    list                  # list apps"
  echo "tbd    check                 # check apps"
  echo "tbd    check details         # check apps and show details"
  echo "tbd    stop|start            # start or stop all apps"
  echo "tbd    state active|disabled # disable/enable app"
  echo "tbd    rm|up|rmup            # start or stop all apps"
  echo "tbd    ps                    # show app containers"
  echo ""
}


verbose=""
CURROPT=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    -v) verbose="1"               ; shift 1 ;;
    *)  CURROPT="$CURROPT \"${1//\"/\\\"}\"" ; shift 1 ;;
  esac
done
eval set -- $CURROPT

if [ "$1" = "" ] ; then
  _show_help
  exit 0
fi

#echo $*
app=$1
shift
CMD="$1"
shift
if [ "$CMD" = "state"  ] ; then
  YML=$(dc-yq .apps.${app}.dc_yml)
  if [ "$1" = "disabled"  ] ; then
    dc -a ${app} rm
    dc-yq -i '.app.home.[].state = "disbaled"' $YML
    exit 0
  elif [ "$1" = "active"  ] ; then
    dc-yq -i '.app.home.[].state = "active"'   $YML
    dc -a ${app} up
    exit 0
  fi
elif [ "$CMD" = "config"  ] ; then
  cmd=$1
  shift
  dc-config $cmd app ${app} $@
  exit $?
elif [[ "$CMD" == "rm" || "$CMD" == "up" || "$CMD" == "rmup" || "$CMD" == "ps" || "$CMD" == "data" || "$CMD" == "logs" || "$CMD" == "login" ]]; then
  dc -a ${app} $CMD $@
  exit $?
fi

exit 0
